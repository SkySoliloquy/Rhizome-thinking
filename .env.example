# MiniMax API Configuration (for LLM processing)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_EMBEDDING_MODEL=embo-01

# SiliconFlow Embedding API Configuration
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# Use mock embedding when API is unavailable (set to true for testing without API)
USE_MOCK_EMBEDDING=false

# Application Settings
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your_random_secret_key_change_in_production

# Storage Paths
STORAGE_DIR=./storage
CHROMA_PERSIST_DIR=./storage/chroma
